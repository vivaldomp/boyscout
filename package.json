{
  "name": "boyscout",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "pnpm -r --parallel typecheck",
    "test": "vitest run",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "golden:update": "UPDATE_GOLDENS=1 vitest run golden"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/node": "20.19.9",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
